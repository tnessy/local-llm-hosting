<%- include("../partials/header", { title: "Add UI friend" }) %>
<p>Creates an Authentik account in <code>grp-ui</code>. Their Open WebUI account appears
   automatically the first time they log in — nothing else to do.</p>
<form method="post" action="/friends/ui">
  <%- include("../partials/csrf-field") %>
  <label>Username <input name="username" required></label>
  <label>Email <input name="email" type="email" required></label>
  <label>Name <input name="name" required></label>
  <button type="submit">Create</button>
</form>
<%- include("../partials/footer") %>
