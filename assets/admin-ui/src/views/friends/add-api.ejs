<%- include("../partials/header", { title: "Add API friend" }) %>
<p>Creates an Authentik account in <code>grp-api</code> and mints a LiteLLM key in one step.</p>
<form method="post" action="/friends/api">
  <%- include("../partials/csrf-field") %>
  <label>Username <input name="username" required></label>
  <label>Email <input name="email" type="email" required></label>
  <label>Name <input name="name" required></label>
  <label>Models (comma-separated) <input name="models" placeholder="coder,chat" required></label>
  <label>Max budget (USD) <input name="maxBudget" type="number" step="0.01" value="20"></label>
  <label>Budget duration <input name="budgetDuration" value="30d"></label>
  <label>RPM limit <input name="rpmLimit" type="number" value="60"></label>
  <button type="submit">Create</button>
</form>
<%- include("../partials/footer") %>
