# Copy to ".env" next to docker-compose.yml and fill in. Never commit the real .env.
# Generate secrets with:  openssl rand -hex 32

# Cloudflare Tunnel token (step 08): Zero Trust > Networks > Tunnels > home-llm
# > Docker connector > copy the token from the `--token <...>` value.
CF_TUNNEL_TOKEN=

# Internal key TabbyAPI requires. Stays inside llmnet; never exposed publicly.
TABBY_API_KEY=

# LiteLLM admin + salt keys (step 06). MASTER_KEY must start with "sk-".
LITELLM_MASTER_KEY=sk-
LITELLM_SALT_KEY=

# A LiteLLM virtual key minted for Open WebUI to call the gateway (step 06/07).
OPENWEBUI_LITELLM_KEY=sk-

# Open WebUI session signing secret (keeps logins valid across restarts).
WEBUI_SECRET_KEY=
